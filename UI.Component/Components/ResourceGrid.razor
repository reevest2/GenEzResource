@using ResourceFramework.Models


@typeparam TResource where TResource : ResourceBase, new()

@inject IMediator Mediator
@inject NotificationService NotificationService

<div class="resource-grid-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>@Title</h3>
        <RadzenButton Text="Create New" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@OnCreateClick" />
    </div>

    <RadzenDataGrid @ref="_grid"
                    TItem="TResource"
                    Data="@_resources"
                    IsLoading="@_isLoading"
                    AllowFiltering="true"
                    AllowColumnResize="true"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="10"
                    PagerHorizontalAlign="HorizontalAlign.Center"
                    FilterMode="FilterMode.Advanced"
                    Style="width: 100%;">
        <Columns>
            @if (Columns != null)
            {
                @Columns
            }
            else
            {
                @_defaultColumns
            }
            <RadzenDataGridColumn TItem="TResource" Title="Actions" Filterable="false" Sortable="false" Width="150px" TextAlign="TextAlign.Center">
                <Template Context="resource">
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  Click="@(() => OnEditClick(resource))" class="me-1" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                  Click="@(() => OnDeleteClick(resource))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

@if (_showEditDialog)
{
    <ResourceEditDialog TResource="TResource"
                        Resource="@_editingResource"
                        IsNew="@_isNewResource"
                        Title="@(_isNewResource ? $"Create {Title}" : $"Edit {Title}")"
                        OnSave="@OnSaveResource"
                        OnCancel="@OnCancelEdit" />
}

@if (_showDeleteConfirm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="@(() => _showDeleteConfirm = false)"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this resource?</p>
                </div>
                <div class="modal-footer">
                    <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => _showDeleteConfirm = false)" />
                    <RadzenButton Text="Delete" ButtonStyle="ButtonStyle.Danger" Click="@ConfirmDelete" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = typeof(TResource).Name;
    [Parameter] public RenderFragment? Columns { get; set; }

    private RadzenDataGrid<TResource>? _grid;
    private List<TResource> _resources = new();
    private bool _isLoading;
    private bool _showEditDialog;
    private bool _showDeleteConfirm;
    private bool _isNewResource;
    private TResource _editingResource = new();
    private TResource? _deletingResource;
    private RenderFragment? _defaultColumns;

    protected override void OnInitialized()
    {
        if (Columns == null)
        {
            _defaultColumns = BuildDefaultColumns();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            _resources = await Mediator.Send(new GetAllResourcesQuery<TResource>());
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", $"Failed to load data: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OnCreateClick()
    {
        _editingResource = new TResource();
        _isNewResource = true;
        _showEditDialog = true;
    }

    private void OnEditClick(TResource resource)
    {
        _editingResource = resource;
        _isNewResource = false;
        _showEditDialog = true;
    }

    private void OnDeleteClick(TResource resource)
    {
        _deletingResource = resource;
        _showDeleteConfirm = true;
    }

    private void OnCancelEdit()
    {
        _showEditDialog = false;
    }

    private async Task OnSaveResource(TResource resource)
    {
        try
        {
            var command = new UpsertResourceCommand<TResource>(
                Data: resource,
                Id: _isNewResource ? null : resource.Id,
                Key1: resource.Key1,
                Key2: resource.Key2,
                Key3: resource.Key3,
                OwnerId: resource.OwnerId
            );

            await Mediator.Send(command);
            NotificationService.Notify(NotificationSeverity.Success, "Success",
                _isNewResource ? "Resource created successfully." : "Resource updated successfully.");
            _showEditDialog = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", $"Failed to save: {ex.Message}");
        }
    }

    private async Task ConfirmDelete()
    {
        if (_deletingResource == null) return;

        try
        {
            await Mediator.Send(new SoftDeleteResourceCommand<TResource>(_deletingResource.Id));
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Resource deleted successfully.");
            _showDeleteConfirm = false;
            _deletingResource = null;
            await LoadData();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", $"Failed to delete: {ex.Message}");
        }
    }

    private RenderFragment BuildDefaultColumns()
    {
        return builder =>
        {
            var type = typeof(TResource);
            var baseProps = typeof(ResourceBase).GetProperties().Select(p => p.Name).ToHashSet();
            var properties = type.GetProperties()
                .Where(p => !baseProps.Contains(p.Name) || p.Name == "Id")
                .ToList();

            foreach (var prop in properties)
            {
                var propName = prop.Name;
                var propType = prop.PropertyType;

                builder.OpenComponent(0, typeof(RadzenDataGridColumn<>).MakeGenericType(typeof(TResource)));
                builder.AddAttribute(1, "Property", propName);
                builder.AddAttribute(2, "Title", propName);

                if (propName == "Id")
                {
                    builder.AddAttribute(3, "Width", "280px");
                }

                builder.CloseComponent();
            }
        };
    }
}
