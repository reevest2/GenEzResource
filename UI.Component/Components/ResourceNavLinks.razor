@using UI.Component.Services
@inject ResourceUIRegistry Registry

@foreach (var registration in Registry.GetAll())
{
    <div class="nav-item px-3">
        <NavLink class="nav-link" href="@($"resources/{registration.RouteName}")">
            <span class="bi bi-table" aria-hidden="true"></span> @registration.DisplayName
        </NavLink>
    </div>
}
