<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <!-- NuGet Package Metadata -->
        <PackageId>ResourceFramework.Server</PackageId>
        <Version>1.0.0</Version>
        <Authors>DemonsAndDogs</Authors>
        <Description>All-in-one server package for the ResourceFramework. Provides ResourceBase models, generic EF Core repository, CRUD services, auto-generated API controllers, and one-line DI registration. Install this single package in your ASP.NET Core Web API project to get full resource CRUD infrastructure.</Description>
        <PackageTags>resource;crud;api;efcore;aspnetcore;generic-controller;repository;nuget</PackageTags>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <IsPackable>true</IsPackable>
    </PropertyGroup>
    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="Microsoft.EntityFrameworkCore" Version="9.0.13" />
        <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" Version="9.0.13" />
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\ResourceFramework.Models\ResourceFramework.Models.csproj" />
    </ItemGroup>
</Project>
